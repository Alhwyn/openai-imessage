#!/usr/bin/env bash
set -euo pipefail

run_id="${1:?run id is required}"
display="${DISPLAY:-:1}"
width="${COMPUTER_DISPLAY_WIDTH:-1280}"
height="${COMPUTER_DISPLAY_HEIGHT:-800}"
fps="${COMPUTER_RECORDING_FPS:-15}"
artifact_dir="/artifacts/${run_id}"
pid_file="${artifact_dir}/recording.pid"
log_file="${artifact_dir}/recording.log"
recording="${artifact_dir}/session.mkv"

mkdir -p "$artifact_dir"

if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
  printf '%s\n' "$recording"
  exit 0
fi

nohup ffmpeg \
  -nostdin \
  -f x11grab \
  -framerate "$fps" \
  -video_size "${width}x${height}" \
  -draw_mouse 1 \
  -i "${display}.0" \
  -an \
  -c:v libx264 \
  -preset veryfast \
  -crf 24 \
  -pix_fmt yuv420p \
  -y "$recording" >"$log_file" 2>&1 &

printf '%s\n' "$!" >"$pid_file"
printf '%s\n' "$recording"
