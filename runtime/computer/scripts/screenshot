#!/usr/bin/env bash
set -euo pipefail

output="${1:-/tmp/computer-screen.png}"
display=":1"
width="1280"
height="800"

mkdir -p "$(dirname "$output")"
pkill -x maim 2>/dev/null || true

# Dual ffmpeg x11grab (session recorder + still capture) wedges Xvnc. Pause any
# live session recorder for the duration of this still frame, then resume.
recorder_pids="$(pgrep -f 'ffmpeg.*x11grab.*session\.mkv' || true)"
resume_recorders() {
  if [[ -n "${recorder_pids}" ]]; then
    # shellcheck disable=SC2086
    kill -CONT ${recorder_pids} 2>/dev/null || true
  fi
}
if [[ -n "${recorder_pids}" ]]; then
  # shellcheck disable=SC2086
  kill -STOP ${recorder_pids} 2>/dev/null || true
  trap resume_recorders EXIT
fi

# Prefer ffmpeg x11grab. maim often hangs forever while the session recorder
# already holds an x11grab on the same display (exit 124 from `timeout`).
capture_with_ffmpeg() {
  local size="$1"
  timeout 8 env DISPLAY="$display" ffmpeg -nostdin -hide_banner -loglevel error -y \
    -f x11grab \
    -video_size "$size" \
    -i "${display}.0" \
    -frames:v 1 \
    -update 1 \
    "$output"
}

if ! timeout 2 xdpyinfo -display "$display" >/dev/null 2>&1; then
  echo "screenshot failed: display ${display} is not available" >&2
  exit 1
fi

if capture_with_ffmpeg "${width}x${height}"; then
  printf '%s\n' "$output"
  exit 0
fi

# Fallback if the live desktop is still at the Kasm boot geometry.
if capture_with_ffmpeg "1024x768"; then
  printf '%s\n' "$output"
  exit 0
fi

# Last resort: maim (may still hang under a live recorder — keep timeout tight).
if timeout 5 env DISPLAY="$display" maim -u "$output"; then
  printf '%s\n' "$output"
  exit 0
fi

echo "screenshot failed: ffmpeg and maim could not capture ${display}" >&2
exit 1
