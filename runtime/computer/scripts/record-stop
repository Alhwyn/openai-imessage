#!/usr/bin/env bash
set -euo pipefail

run_id="${1:?run id is required}"
artifact_dir="/artifacts/${run_id}"
pid_file="${artifact_dir}/recording.pid"
source_file="${artifact_dir}/session.mkv"
output_file="${artifact_dir}/demo.mp4"

if [[ -f "$pid_file" ]]; then
  pid="$(cat "$pid_file")"
  if kill -0 "$pid" 2>/dev/null; then
    kill -INT "$pid"
    for _ in $(seq 1 100); do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.1
    done
  fi
  rm -f "$pid_file"
fi

if [[ ! -s "$source_file" ]]; then
  printf '%s\n' "recording was not created" >&2
  exit 1
fi

ffmpeg -nostdin -i "$source_file" -c copy -movflags +faststart -y "$output_file"
printf '%s\n' "$output_file"
